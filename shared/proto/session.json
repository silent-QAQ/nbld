{
  "module": "session",
  "version": 2,
  "endpoints": [
    {
      "name": "healthz",
      "method": "GET",
      "path": "/healthz",
      "response": {
        "status": "string",
        "instanceId": "string",
        "startedAt": "rfc3339"
      }
    },
    {
      "name": "guest_login",
      "method": "POST",
      "path": "/api/v1/session/guest",
      "request": {
        "deviceId": "string"
      },
      "response": {
        "playerId": "string",
        "token": "string",
        "serverTime": "rfc3339"
      }
    },
    {
      "name": "register",
      "method": "POST",
      "path": "/api/v1/session/register",
      "request": {
        "email": "string",
        "username": "string",
        "password": "string",
        "confirmPassword": "string"
      },
      "response": {
        "accountId": "string",
        "email": "string",
        "username": "string",
        "serverTime": "rfc3339"
      }
    },
    {
      "name": "login",
      "method": "POST",
      "path": "/api/v1/session/login",
      "request": {
        "email": "string",
        "password": "string"
      },
      "response": {
        "accountId": "string",
        "email": "string",
        "username": "string",
        "token": "string",
        "serverTime": "rfc3339"
      }
    },
    {
      "name": "list_characters",
      "method": "GET",
      "path": "/api/v1/characters?token={token}",
      "response": {
        "activeLimit": "int",
        "deletedLimit": "int",
        "active": [
          {
            "id": "string",
            "name": "string",
            "stats": "characterStats",
            "inventory": "itemContainer",
            "warehouse": "itemContainer",
            "position": "characterPosition",
            "equipment": "characterEquipment",
            "createdAt": "rfc3339",
            "updatedAt": "rfc3339"
          }
        ],
        "deleted": [
          {
            "id": "string",
            "name": "string",
            "stats": "characterStats",
            "inventory": "itemContainer",
            "warehouse": "itemContainer",
            "position": "characterPosition",
            "equipment": "characterEquipment",
            "deletedAt": "rfc3339",
            "purgeAt": "rfc3339",
            "createdAt": "rfc3339",
            "updatedAt": "rfc3339"
          }
        ]
      }
    },
    {
      "name": "create_character",
      "method": "POST",
      "path": "/api/v1/characters/create",
      "request": {
        "token": "string",
        "name": "string"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "update_character_stats",
      "method": "POST",
      "path": "/api/v1/characters/stats",
      "request": {
        "token": "string",
        "characterId": "string",
        "stats": "characterStats",
        "note": "开发期兼容接口。服务端只接受基础/来源层，derived/combat 由服务端重算。"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "update_character_inventory",
      "method": "POST",
      "path": "/api/v1/characters/inventory",
      "request": {
        "token": "string",
        "characterId": "string",
        "inventory": "itemContainer"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "update_character_warehouse",
      "method": "POST",
      "path": "/api/v1/characters/warehouse",
      "request": {
        "token": "string",
        "characterId": "string",
        "warehouse": "itemContainer"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "update_character_equipment",
      "method": "POST",
      "path": "/api/v1/characters/equipment",
      "request": {
        "token": "string",
        "characterId": "string",
        "equipment": "characterEquipment"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "delete_character",
      "method": "POST",
      "path": "/api/v1/characters/delete",
      "request": {
        "token": "string",
        "characterId": "string"
      },
      "response": {
        "character": "characterSummary"
      }
    },
    {
      "name": "enter_world",
      "method": "POST",
      "path": "/api/v1/world/enter",
      "request": {
        "token": "string",
        "characterId": "string"
      },
      "response": {
        "playerId": "string",
        "characterId": "string",
        "characterName": "string",
        "worldId": "string",
        "mapId": "string",
        "position": {
          "x": "float64",
          "y": "float64"
        }
      }
    },
    {
      "name": "leave_world",
      "method": "POST",
      "path": "/api/v1/world/leave",
      "request": {
        "token": "string"
      },
      "response": {
        "playerId": "string",
        "characterId": "string",
        "status": "left_world"
      }
    },
    {
      "name": "get_world_state",
      "method": "GET",
      "path": "/api/v1/world/state?token={token}",
      "response": {
        "worldId": "string",
        "mapId": "string",
        "playerId": "string",
        "characterId": "string",
        "characterName": "string",
        "position": {
          "x": "float64",
          "y": "float64"
        },
        "biome": "string",
        "seed": "int64",
        "players": [
          {
            "playerId": "string",
            "characterId": "string",
            "characterName": "string",
            "mapId": "string",
            "position": {
              "x": "float64",
              "y": "float64"
            }
          }
        ]
      }
    },
    {
      "name": "move_player",
      "method": "POST",
      "path": "/api/v1/world/move",
      "request": {
        "token": "string",
        "position": {
          "x": "float64",
          "y": "float64"
        }
      },
      "response": {
        "playerId": "string",
        "characterId": "string",
        "mapId": "string",
        "position": {
          "x": "float64",
          "y": "float64"
        }
      }
    },
    {
      "name": "world_events",
      "method": "GET",
      "path": "/api/v1/world/events?token={token}",
      "response": {
        "contentType": "text/event-stream",
        "events": [
          {
            "type": "connected | player_moved",
            "playerId": "string",
            "characterId": "string",
            "characterName": "string",
            "mapId": "string",
            "position": {
              "x": "float64",
              "y": "float64"
            },
            "occurredAt": "rfc3339"
          }
        ]
      }
    },
    {
      "name": "world_ws",
      "method": "GET",
      "path": "/ws/world",
      "request": {
        "firstMessage": {
          "type": "auth",
          "token": "string"
        },
        "messages": [
          {
            "type": "move",
            "position": {
              "x": "float64",
              "y": "float64"
            }
          }
        ]
      },
      "response": {
        "messages": [
          {
            "type": "auth_ok | player_moved | map_transition | error",
            "playerId": "string",
            "characterId": "string",
            "characterName": "string",
            "worldId": "string",
            "mapId": "string",
            "position": {
              "x": "float64",
              "y": "float64"
            },
            "players": [
              {
                "playerId": "string",
                "characterId": "string",
                "characterName": "string",
                "mapId": "string",
                "position": {
                  "x": "float64",
                  "y": "float64"
                }
              }
            ],
            "error": "string"
          }
        ]
      }
    }
  ]
  ,
  "schemas": {
    "attributeValues": {
      "type": "map<string,float64>",
      "keys": [
        "health",
        "stamina",
        "mana",
        "move_speed",
        "physical_attack",
        "magic_attack",
        "physical_defense",
        "magic_defense",
        "physical_crit",
        "magic_crit",
        "crit_damage_bonus",
        "damage_bonus",
        "extra_damage",
        "crit_resist",
        "damage_immunity",
        "extra_immunity",
        "heal_power",
        "heal_taken_bonus"
      ]
    },
    "characterStats": {
      "level": "int",
      "base": "legacyCharacterBaseStats",
      "attack": "legacyCharacterAttackStats",
      "defense": "legacyCharacterDefenseStats",
      "sources": {
        "base": "attributeValues",
        "levelGrowth": "attributeValues",
        "talent": "attributeValues",
        "equipment": "attributeValues",
        "passiveGem": "attributeValues",
        "buff": "attributeValues",
        "system": "attributeValues",
        "manual": "attributeValues"
      },
      "derived": {
        "baseStats": "attributeValues",
        "derivedStats": "attributeValues",
        "combatStats": "attributeValues"
      },
      "combat": {
        "resources": {
          "healthMax": "int",
          "healthCurrent": "int",
          "manaMax": "int",
          "manaCurrent": "int",
          "staminaMax": "int",
          "staminaCurrent": "int"
        },
        "physicalAttack": "int",
        "magicAttack": "int",
        "physicalDefense": "int",
        "magicDefense": "int",
        "moveSpeed": "float64",
        "physicalCrit": "ratio",
        "magicCrit": "ratio",
        "critDamageBonus": "ratio",
        "damageBonus": "ratio",
        "extraDamage": "ratio",
        "critResist": "ratio",
        "damageImmunity": "ratio",
        "extraImmunity": "ratio",
        "healPower": "ratio",
        "healTakenBonus": "ratio",
        "powerScore": "int"
      },
      "metadata": {
        "schemaVersion": "int",
        "profileId": "string",
        "attributeDefs": "attributeDefinition[]",
        "warnings": "string[]"
      }
    },
    "attributeDefinition": {
      "code": "string",
      "displayName": "string",
      "category": "base | attack | defense | healing",
      "valueKind": "flat | ratio",
      "defaultValue": "float64",
      "minValue": "float64",
      "maxValue": "float64",
      "clientVisible": "bool",
      "description": "string"
    }
  }
}
